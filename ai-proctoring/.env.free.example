# 🆓 FREE AI PROCTORING SERVICE - Environment Configuration
# No API keys required - uses local OpenCV models only

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# FastAPI Server
HOST=0.0.0.0
PORT=5000
ENVIRONMENT=development

# ===========================================
# FREE AI MODEL CONFIGURATION
# ===========================================

# No OpenAI API required - using free local models
AI_PROVIDER=local_opencv
MODEL_TYPE=free_open_source

# Computer Vision Configuration (Free)
CV_MODEL=haarcascade_frontalface_default.xml
FACE_DETECTION_CONFIDENCE=0.7
MOTION_DETECTION_THRESHOLD=25
EYE_DETECTION_ENABLED=true
HEAD_POSE_ESTIMATION=true
OBJECT_DETECTION_ENABLED=true

# Advanced Free Models (Optional)
# Uncomment to enable enhanced free models
USE_DNN_FACE_DETECTOR=false
USE_CONTOUR_ANALYSIS=true
USE_BEHAVIOR_ANALYSIS=true

# Frame Processing
FRAME_CAPTURE_INTERVAL=5  # seconds
MAX_FRAMES_STORED=100
FRAME_QUALITY=85

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# PostgreSQL (if using external database)
DATABASE_URL=postgresql://postgres:password@localhost:5432/proctoring_db

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/proctoring.log

# ===========================================
# API CONFIGURATION
# ===========================================

# Backend API connection
BACKEND_API_URL=http://localhost:4000/api
API_TIMEOUT=30

# ===========================================
# PRODUCTION CONFIGURATION
# ===========================================

# Uncomment and update these for production deployment

# ENVIRONMENT=production
# LOG_LEVEL=WARNING
# BACKEND_API_URL=https://api.exam.yourdomain.com/api
# DATABASE_URL=postgresql://user:password@postgres-service:5432/proctoring_db
# REDIS_URL=redis://redis-service:6379/0

# Security
CORS_ORIGINS=["https://exam.yourdomain.com", "https://api.exam.yourdomain.com"]
ALLOWED_HOSTS=["exam.yourdomain.com", "api.exam.yourdomain.com"]

# ===========================================
# COST & PRIVACY
# ===========================================

# Total cost: $0.00 (100% free)
# Privacy: All processing done locally
# Data: No data sent to external services
# Dependencies: OpenCV, NumPy (open source)
