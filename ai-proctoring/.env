# 🤖 AI Proctoring Service - Local Development Environment
# This file is automatically generated for local development

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# FastAPI Server
HOST=0.0.0.0
PORT=5000
ENVIRONMENT=development

# ===========================================
# AI MODEL CONFIGURATION
# ===========================================

# OpenAI Configuration (Optional - for enhanced AI detection)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-vision-preview

# Computer Vision Configuration
CV_MODEL=haarcascade_frontalface_default.xml
FACE_DETECTION_CONFIDENCE=0.7
MOTION_DETECTION_THRESHOLD=25

# Frame Processing
FRAME_CAPTURE_INTERVAL=5  # seconds
MAX_FRAMES_STORED=100
FRAME_QUALITY=85

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# PostgreSQL (if using external database)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proctoring_db

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/proctoring.log

# ===========================================
# API CONFIGURATION
# ===========================================

# Backend API connection
BACKEND_API_URL=http://localhost:4000/api
API_TIMEOUT=30

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

CORS_ORIGINS=["http://localhost:3000", "http://localhost:4000"]
ALLOWED_HOSTS=["localhost:3000", "localhost:4000", "localhost:5000"]
