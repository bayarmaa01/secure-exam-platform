# 🔒 Secure Exam Platform - Environment Configuration Example
# Copy this file to .env and update with your actual values

# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=exam_platform
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-256-bits
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-256-bits
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (for password reset)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================

# API Configuration
VITE_API_URL=http://localhost:4005/api
VITE_AI_URL=http://localhost:5005

# Environment
VITE_ENVIRONMENT=development

# ===========================================
# AI PROCTORING ENVIRONMENT VARIABLES
# ===========================================

# OpenAI Configuration (Optional - for enhanced AI detection)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=5000
ENVIRONMENT=development

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===========================================

# Uncomment and update these for production deployment

# PORT=4000
# NODE_ENV=production
# 
# DB_HOST=postgres-service
# DB_PORT=5432
# DB_NAME=exam_platform
# DB_USER=postgres
# DB_PASSWORD=your-secure-password
# 
# REDIS_URL=redis://redis-service:6379
# 
# JWT_SECRET=your-production-jwt-secret-256-bits-minimum
# JWT_REFRESH_SECRET=your-production-refresh-secret-256-bits-minimum
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# 
# CORS_ORIGIN=https://exam.yourdomain.com
# 
# VITE_API_URL=http://localhost:4005/api
# VITE_AI_URL=http://localhost:5005
# VITE_ENVIRONMENT=production
# 
# OPENAI_API_KEY=sk-your-production-openai-key

# ===========================================
# DOCKER COMPOSE OVERRIDES
# ===========================================

# Create a .env.local file to override these values for local development
# This file should be added to .gitignore

# Example .env.local:
# PORT=4001
# DB_PASSWORD=mypassword
# CORS_ORIGIN=http://localhost:3001
