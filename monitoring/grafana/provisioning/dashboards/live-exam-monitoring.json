{
  "dashboard": {
    "id": null,
    "title": "Live Exam Monitoring",
    "tags": ["exam", "monitoring", "live"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Active Exams",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(exam_active_sessions)",
            "legendFormat": "{{__value__.labels}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              },
              "displayMode": "list",
              "orientation": "horizontal",
              "text": {},
              "mappings": [],
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "red",
                    "value": 80
                  }
                ],
                "mode": "absolute"
              }
            },
            "overrides": []
          },
          "overrides": [],
          "unit": "short"
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": [
            {
              "calcs": [
                "lastNotNull"
              ],
              "fields": "",
              "values": false
            }
          ],
          "textMode": "auto"
        },
        "pluginVersion": "9.0.0",
        "targets": [
          {
            "expr": "sum(exam_active_sessions)",
            "interval": "",
            "legendFormat": "{{__value__.labels}}"
          }
        ],
        "title": "Active Exams",
        "type": "stat"
